{
  "description": "Context compression hooks for built-in tool output",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/compress-read.sh", "timeout": 10}]
      },
      {
        "matcher": "Grep",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/compress-grep.sh", "timeout": 10}]
      },
      {
        "matcher": "Glob",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/compress-glob.sh", "timeout": 10}]
      }
    ]
  }
}
